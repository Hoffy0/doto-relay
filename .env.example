# doto environment variables
# Copy to .env in your project directory — DOTO_ vars are picked up automatically.
# Precedence: shell export > project .env > ~/.config/doto/config.env

# ── DB mode ──────────────────────────────────────────────────────────────────
# Without DOTO_DB_URL → SQLite local (default, one doto.db per project)
# With DOTO_DB_URL    → Postgres / Supabase (shared across machines)

# DOTO_DB_URL=postgresql://usuario:password@host:5432/dbname

# Supabase example:
# DOTO_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ── Runtime (set automatically by `doto start`, no need to touch) ─────────────
# DOTO_AGENT_ID=<uuid>       agent UUID registered in the DB
# DOTO_PROJECT_ID=<uuid>     project UUID registered in the DB
# DOTO_DB_PATH=<path>        absolute path to doto.db (SQLite mode only)
